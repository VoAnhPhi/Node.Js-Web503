<main class="main-content">
    <div class="add-product-wrapper">
        <header class="add-product-header">
            <h1 class="add-product-title">Chỉnh sửa danh mục</h1>
        </header>

        <form id="editCategoryForm" class="add-product-form">
            <div class="add-product-input-wrapper">
                <label for="editCategoryName" class="add-product-input-label">Tên danh mục</label>
                <input type="text" id="editCategoryName" class="add-product-input" placeholder="Nhập tên danh mục"
                    required />
            </div>

            <div class="add-product-input-wrapper">
                <label for="editCategoryStatus" class="add-product-input-label">Trạng thái</label>
                <div class="add-product-select-wrapper">
                    <select id="editCategoryStatus" class="add-product-select">
                        <option value="1">Hiển thị</option>
                        <option value="0">Ẩn</option>
                    </select>
                    <img src="https://cdn.builder.io/api/v1/image/assets/TEMP/5ce3312dee92806ec00e2d79ae205b9c41db31566e3ccaf3cc9023b17706835e?placeholderIfAbsent=true&apiKey=c01b0b1f77f44db1a01eba6bb534c16f"
                        alt="" width="14" height="7" aria-hidden="true" />
                </div>
            </div>

            <button type="submit" class="add-product-save-btn" id="updateCategoryBtn">
                <img src="https://cdn.builder.io/api/v1/image/assets/TEMP/ace380a4e6c699359f5dda7129c4479965ce48f6f711bc8bae14781f41cb0093?placeholderIfAbsent=true&apiKey=c01b0b1f77f44db1a01eba6bb534c16f"
                    alt="Save Icon" width="18" height="18" />
                Cập nhật
            </button>
        </form>

        <p id="editCategoryMessage" class="add-product-message"></p>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const urlParams = new URLSearchParams(window.location.search);
        const categoryId = urlParams.get("id"); // Lấy ID danh mục từ URL

        if (!categoryId) {
            const messageBox = document.getElementById("editCategoryMessage");
            messageBox.textContent = "Không tìm thấy ID danh mục.";
            messageBox.style.color = "red";
            return;
        }

        // Lấy token từ sessionStorage
        let token = sessionStorage.getItem('token');
        let user = sessionStorage.getItem('user') ? JSON.parse(sessionStorage.getItem('user')) : null;

        if (!token || !user) {
            alert('Bạn cần đăng nhập để sử dụng chức năng này');
            window.location.href = '/admin/login';
        }

        const headers = {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json'
        };

        const categoryNameInput = document.getElementById("editCategoryName");
        const categoryStatusSelect = document.getElementById("editCategoryStatus");
        const messageBox = document.getElementById("editCategoryMessage");

        // Hàm fetch dữ liệu danh mục
        function fetchCategoryData() {
            fetch(`/admin/api/get-all-category`, { method: "GET", headers })
                .then(response => {
                    if (!response.ok) return response.json().then(err => Promise.reject(err));
                    return response.json();
                })
                .then(categories => {
                    const category = categories.find(cat => cat.id == categoryId);
                    if (!category) throw new Error("Không tìm thấy danh mục.");
                    categoryNameInput.value = category.ten_loai;
                    categoryStatusSelect.value = category.an_hien;
                })
                .catch(error => {
                    messageBox.textContent = error.message || "Lỗi khi tải danh mục.";
                    messageBox.style.color = "red";
                });
        }

        // Hàm cập nhật danh mục
        function updateCategory(event) {
            event.preventDefault();

            const updatedName = categoryNameInput.value.trim();
            const updatedStatus = categoryStatusSelect.value;

            if (!updatedName) {
                messageBox.textContent = "Tên danh mục không được để trống.";
                messageBox.style.color = "red";
                return;
            }

            const updatedData = {
                ten_loai: updatedName,
                an_hien: Number(updatedStatus)
            };

            fetch(`/admin/api/update-category/${categoryId}`, {
                method: "PUT",
                headers: headers,
                body: JSON.stringify(updatedData)
            })
                .then(response => {
                    if (!response.ok) return response.json().then(err => Promise.reject(err));
                    return response.json();
                })
                .then(() => {
                    messageBox.textContent = "Cập nhật danh mục thành công!";
                    messageBox.style.color = "green";
                })
                .catch(error => {
                    messageBox.textContent = error.thong_bao || "Có lỗi xảy ra khi cập nhật danh mục.";
                    messageBox.style.color = "red";
                });
        }

        // Thêm sự kiện submit form
        document.getElementById("editCategoryForm").addEventListener("submit", updateCategory);

        // Gọi API để lấy dữ liệu danh mục khi trang tải lên
        fetchCategoryData();
    });
</script>